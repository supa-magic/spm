{
  "name": "@supa-magic/spm",
  "version": "0.4.0",
  "description": "CLI tool for managing AI skillsets",
  "license": "MIT",
  "contributors": [
    "sultan99",
    "bafxyz"
  ],
  "keywords": [
    "ai",
    "cli",
    "package manager",
    "skills",
    "skillsets",
    "spm",
    "supa-magic"
  ],
  "type": "module",
  "bin": {
    "spm": "dist/bin/spm.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "pretest": "npm run build",
    "start": "clear && claude --dangerously-skip-permissions",
    "test": "vitest run",
    "test:watch": "vitest",
    "un": "npm uninstall @supa-magic/spm",
    "unlink": "npm unlink spm"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "^25.5.0",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.8.2"
  }
}
